<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EMI Planning - AgriFlow</title>
    <link rel="stylesheet" href="/css/agriflow.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .emi-planner-container {
            max-width: 900px;
            margin: 40px auto;
            background: white;
            border-radius: 15px;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        .emi-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 40px;
            text-align: center;
        }

        .emi-header h1 {
            margin: 0;
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .emi-header p {
            margin: 0;
            opacity: 0.9;
            font-size: 16px;
        }

        .form-section {
            padding: 40px;
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
        }

        .form-group label {
            font-weight: 600;
            margin-bottom: 8px;
            color: #333;
            font-size: 14px;
        }

        .form-group input,
        .form-group select {
            padding: 12px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 14px;
            transition: all 0.3s ease;
            font-family: 'Poppins', sans-serif;
        }

        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .form-group-full {
            grid-column: 1 / -1;
        }

        .info-box {
            background: #f0f4ff;
            border-left: 4px solid #667eea;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 14px;
            color: #333;
        }

        .submit-section {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-top: 40px;
            padding-top: 30px;
            border-top: 2px solid #f0f0f0;
        }

        .btn-primary,
        .btn-secondary {
            padding: 14px 40px;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Poppins', sans-serif;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(102, 126, 234, 0.3);
        }

        .btn-secondary {
            background: #f0f0f0;
            color: #333;
        }

        .btn-secondary:hover {
            background: #e0e0e0;
        }

        .loading {
            display: none;
            text-align: center;
            padding: 30px;
        }

        .spinner {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #667eea;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto 15px;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .error-box {
            display: none;
            background: #ffe0e0;
            border-left: 4px solid #d32f2f;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            color: #d32f2f;
        }

        .input-range-display {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 5px;
        }

        .range-value {
            background: #667eea;
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 14px;
            min-width: 70px;
            text-align: center;
        }

        @media (max-width: 768px) {
            .form-grid {
                grid-template-columns: 1fr;
            }

            .submit-section {
                flex-direction: column;
            }

            .btn-primary,
            .btn-secondary {
                width: 100%;
            }

            .emi-header h1 {
                font-size: 24px;
            }

            .form-section {
                padding: 20px;
            }
        }
    </style>
</head>

<body>
    <%- include('partials/navbar-agriflow') %>

    <div class="emi-planner-container">
        <div class="emi-header">
            <h1>📊 Plan Your EMI Schedule</h1>
            <p>Dynamic EMI optimization based on your predicted income & risk profile</p>
        </div>

        <div class="form-section">
            <div class="error-box" id="errorBox"></div>

            <form id="emiPlanForm">
                <div class="info-box">
                    📌 Enter your loan details below. Our AI will analyze your predicted income and default risk to create an optimized payment schedule.
                </div>

                <div class="form-grid">
                    <!-- Farmer Information -->
                    <div class="form-group">
                        <label for="name">👤 Farmer Name</label>
                        <input type="text" id="name" name="name" placeholder="e.g., राज कुमार" required>
                    </div>

                    <div class="form-group">
                        <label for="state">🗺️ State</label>
                        <select id="state" name="state" required>
                            <option value="">Select State</option>
                            <option value="MP">Madhya Pradesh</option>
                            <option value="UP">Uttar Pradesh</option>
                            <option value="RJ">Rajasthan</option>
                            <option value="PB">Punjab</option>
                            <option value="HR">Haryana</option>
                            <option value="MH">Maharashtra</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="district">📍 District</label>
                        <input type="text" id="district" name="district" placeholder="e.g., Vidisha" required>
                    </div>

                    <div class="form-group">
                        <label for="crop">🌾 Primary Crop</label>
                        <select id="crop" name="crop" required>
                            <option value="">Select Crop</option>
                            <option value="Wheat">Wheat (गेहूं)</option>
                            <option value="Rice">Rice (धान)</option>
                            <option value="Cotton">Cotton (कपास)</option>
                            <option value="Sugarcane">Sugarcane (गन्ना)</option>
                            <option value="Soybean">Soybean (सोयाबीन)</option>
                            <option value="Corn">Corn (मक्का)</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="irrigation">💧 Irrigation Type</label>
                        <select id="irrigation" name="irrigation" required>
                            <option value="">Select Irrigation</option>
                            <option value="Borewell">Borewell (बोरवेल)</option>
                            <option value="Canal">Canal (नहर)</option>
                            <option value="Rainfed">Rainfed (वर्षा आश्रित)</option>
                            <option value="Drip">Drip Irrigation (ड्रिप)</option>
                            <option value="Sprinkler">Sprinkler (स्प्रिंकलर)</option>
                        </select>
                    </div>

                    <!-- Loan Details -->
                    <div class="form-group form-group-full">
                        <label for="loanAmount">💰 Loan Amount (₹)</label>
                        <input type="number" id="loanAmount" name="loanAmount" placeholder="e.g., 50000" min="5000" max="10000000" step="1000" required>
                        <small style="color: #999; margin-top: 5px;">Min: ₹5,000 | Max: ₹1 Crore</small>
                    </div>

                    <div class="form-group form-group-full">
                        <label for="duration">📅 Loan Duration (Months)
                            <span class="range-value" id="durationDisplay">12</span>
                        </label>
                        <input type="range" id="duration" name="duration" min="6" max="60" value="12" step="1" style="width: 100%;">
                        <small style="color: #999; margin-top: 5px;">6 to 60 months</small>
                    </div>
                </div>

                <div class="submit-section">
                    <button type="submit" class="btn-primary">
                        <span id="submitText">Generate EMI Plan 🚀</span>
                        <span class="spinner" id="spinner" style="display: none; margin: 0 0 0 10px; border-width: 2px; width: 20px; height: 20px;"></span>
                    </button>
                    <button type="reset" class="btn-secondary">Clear Form</button>
                </div>
            </form>

            <div class="loading" id="loading">
                <div class="spinner"></div>
                <p>📊 Analyzing your farm data and generating EMI plan...</p>
            </div>
        </div>
    </div>

    <script>
        // Update duration display
        document.getElementById('duration').addEventListener('input', (e) => {
            document.getElementById('durationDisplay').textContent = e.target.value;
        });

        // Form submission
        document.getElementById('emiPlanForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            // Validation
            if (!document.getElementById('name').value.trim()) {
                showError('Please enter farmer name');
                return;
            }

            // Show loading
            document.getElementById('loading').style.display = 'block';
            document.getElementById('emiPlanForm').style.display = 'none';
            document.getElementById('errorBox').style.display = 'none';

            try {
                const formData = new FormData(document.getElementById('emiPlanForm'));
                const data = Object.fromEntries(formData);

                const response = await fetch('/api/emi-plan', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (response.ok && result.status !== 'error') {
                    // Store result and redirect
                    sessionStorage.setItem('emiReport', JSON.stringify(result));
                    window.location.href = '/emi-plan-result';
                } else {
                    throw new Error(result.error || 'Failed to generate plan');
                }
            } catch (error) {
                console.error('Error:', error);
                showError(`Error: ${error.message}`);
                document.getElementById('loading').style.display = 'none';
                document.getElementById('emiPlanForm').style.display = 'block';
            }
        });

        function showError(message) {
            const errorBox = document.getElementById('errorBox');
            errorBox.textContent = message;
            errorBox.style.display = 'block';
        }
    </script>

    <%- include('partials/footer-agriflow') %>
</body>

</html>